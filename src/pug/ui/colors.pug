include ../layouts/_mixins-links.pug
block variables

<!DOCTYPE html>
html(lang="ru")
	head
		meta(charset="UTF-8")
		meta(name="viewport", content="width=device-width, initial-scale=1.0")
		meta(http-equiv="X-UA-Compatible", content="ie=edge")

		//====убрать синий цвет у ссылок в сафари ========
		meta(name="format-detection" content="telephone=no")
		link(rel="stylesheet", href="../css/main.css")
		title UI-KIT

	body.body-dashboard
		
		include ui-navigation.pug

		block content
			.container-dashboard
				h2.db-h2 Цветовая схема
				.container-dashboard__content
					ul.color-scheme
						li
							span.color-box(style="background-color:#333333;")
							span.color-name --text - #333333;
						li
							span.color-box(style="background-color:#999999;")
							span.color-name --grey - #999999;
						li
							span.color-box(style="background-color:#3180dd;")
							span.color-name --prim - #3180dd;
						
					
					br
					//- .dark-bg(style="height:100px;")
					
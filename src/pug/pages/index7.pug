extends ../layouts/layout.pug

block content
	.form-wrapper
		.form-wrapper-title Опросный лист. Регулятор прямого действия
		form.custom-form.js-validate-form
			//BLOCK №1
			.fieldset
				.fieldset-title 1. Контактная информация
				.form-two-cols
					//single form item
					.form-item-group
						.form-label Название компании*
						.form-item
							input.form-inp(type="text" name="COMPANY_TITLE" value="<?= $data['COMPANY_TITLE'] ?>" data-required)
					
					//single form item
					.form-item-group
						.form-label Контактное лицо*
						.form-item
							input.form-inp(type="text" name="NAME" value="<?= $data['NAME'] ?>"  data-required)
							
					//single form item
					.form-item-group
						.form-label Телефон/факс*
						.form-item
							input.form-inp.phone(type="text" name="PHONE" value="<?= $data['PHONE'] ?>" data-required)
				
					//single form item
					.form-item-group
						.form-label E-mail*
						.form-item
							input.form-inp(type="email" name="EMAIL" value="<?= $data['EMAIL'] ?>" data-required)
			.fieldset.border-0
				.fieldset-title 2. Параметры
				//группа Продукт
				.fieldset-group
					.form-item-group
						.form-label Расход пара (кг/ч)
						.inputs-row
							.form-item
								input.form-inp(type="number" name="p11" )
								span.form-span min
							
							.form-item
								input.form-inp(type="number" name="p12" )
								span.form-span max
					.form-two-cols
						.form-item-group
							.form-label Давление пара #[span.hide-xl (бар изб)]
							.form-item
								input.form-inp(type="number" name="p2"  required)
								span.form-span.hide-xs бар изб
						.form-item-group
							.form-label Настройка (или диапазон настройки) #[span.hide-xl (бар изб./°С)]
							.form-item
								input.form-inp(type="text"  name="p3" required)
								span.form-span.hide-xs бар изб./°С
						
						.form-item-group
							.form-label Минимальная температура окружающей среды
							.form-item
								input.form-inp(type="number" name="p4" required)
								span.form-span °С
						
						.form-item-group
							.form-label Температура пара (указать только если пар перегретый)
							.form-item
								input.form-inp(type="number" name="p5" required)
								span.form-span °С
						
					
						.form-item-group
							.form-label Место установки: магистральный паропровод, теплообменник, калорифер, другое (указать)
							.inputs-row
								.form-item
									input.form-inp(type="text" name="p6" required)
						
						//single form item
						.form-item-group
							.form-label Тип присоединения
							.dropdown
								button.dropdown__button(type="button" aria-haspopup="listbox" aria-expanded="false") В помещении
								.dropdown__list
									ul
										li.dropdown__list-item
											label.form-radio-label
												input(type="radio"  name="tipp1" value="1"  checked )
												span.fake-radio
												span.form-radio-name Резьбовой
										li.dropdown__list-item
											label.form-radio-label
												input(type="radio"  name="tipp1"  value="2")
												span.fake-radio
												span.form-radio-name Фланцевый
								
								

				.fieldset-sticky-subgroup
					.sticky-subgroup-title.h-20 Дополнительное оборудование:
					//row
					.fieldset-sticky-row
						//Левая колонка
						.fieldset-cell-name Фильтр
						
						//Три правые колонки
						.fieldset-sticky-cols.fieldset-cell--center
							.inner-row
								.fieldset-cell
									label.form-checkbox-label
										input(type="checkbox" name="filter1" value="1" )
								.fieldset-cell
									
									label.form-checkbox-label
										input(type="checkbox" name="filter1" value="2")
								.fieldset-cell
									
									label.form-checkbox-label
										input(type="checkbox" name="filter1" value="3")
					//row
					.fieldset-sticky-row
						.fieldset-cell-name Предохранительный клапан
						//Три правые колонки
						.fieldset-sticky-cols.fieldset-cell--center
							.inner-row
								.fieldset-cell
									label.form-checkbox-label
										input(type="checkbox" name="predk1" value="1")
								.fieldset-cell
									
									label.form-checkbox-label
										input(type="checkbox" name="predk1" value="2")
								.fieldset-cell
									
									label.form-checkbox-label
										input(type="checkbox" name="cpredk1" value="3")
					//row
					.fieldset-sticky-row
						.fieldset-cell-name Отсечные вентили / байпасный вентиль
						//Три правые колонки
						.fieldset-sticky-cols.fieldset-cell--center
							.inner-row
								.fieldset-cell
									label.form-checkbox-label
										input(type="checkbox" name="ventil1" value="1")
								.fieldset-cell
									
									label.form-checkbox-label
										input(type="checkbox" name="ventil1" value="2")
										
								.fieldset-cell
									label.form-checkbox-label
										input(type="checkbox" name="ventil1" value="3")
					//row
					.fieldset-sticky-row
						.fieldset-cell-name Конденсатоотводчик дренажа паропровода 
						//Три правые колонки
						.fieldset-sticky-cols.fieldset-cell--center
							.inner-row
								.fieldset-cell
									label.form-checkbox-label
										input(type="checkbox" name="kond1" value="1")
										
								.fieldset-cell
									label.form-checkbox-label
										input(type="checkbox" name="kond1" value="2")
										
								.fieldset-cell
									label.form-checkbox-label
										input(type="checkbox" name="kond1" value="3")
					//row
					.fieldset-sticky-row
						.fieldset-cell-name Термометры / манометры
						//Три правые колонки
						.fieldset-sticky-cols.fieldset-cell--center
							.inner-row
								.fieldset-cell
									label.form-checkbox-label
										input(type="checkbox" name="term1" value="1")
								.fieldset-cell
									
									label.form-checkbox-label
										input(type="checkbox" name="term1" value="2")
								.fieldset-cell
									label.form-checkbox-label
										input(type="checkbox" name="term1" value="3")
							
				
				
				//Поле комментария
				.fieldset-group 
					.form-item-group
						.form-label Примечание
						textarea.form-textarea(name="COMMENTS" id="input")
				.form-footer
					p.fs-15.txt-grey * Если вы затрудняетесь в определении каких-либо значений, свяжитесь с нами, мы поможем их определить, основываясь на дополнительной информации о процессе / установке. Поля, отмеченные *, являются обязательными для заполнения.
					.agree-block
						label.agree-block-label
							input(type="checkbox")
							span Принимаю условия политики конфиден&shy;ци&shy;аль&shy;ности и обработки персональных данных
					.form-button-wrapper
						button.form-button(type="submit") Отправить
block variables
	-var title = "Регулятор прямого действия";

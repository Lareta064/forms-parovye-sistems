extends ../layouts/layout.pug

block content
	.form-wrapper
		.form-wrapper-title Опросный лист. Эжектор
		form.custom-form.js-validate-form
			//BLOCK №1
			.fieldset
				.fieldset-title 1. Контактная информация
				.form-two-cols
					//single form item
					.form-item-group
						.form-label Название компании*
						.form-item
							input.form-inp(type="text" name="COMPANY_TITLE" value="<?= $data['COMPANY_TITLE'] ?>" data-required)
					
					//single form item
					.form-item-group
						.form-label Контактное лицо*
						.form-item
							input.form-inp(type="text" name="NAME" value="<?= $data['NAME'] ?>"  data-required)
							
					//single form item
					.form-item-group
						.form-label Телефон/факс*
						.form-item
							input.form-inp.phone(type="text" name="PHONE" value="<?= $data['PHONE'] ?>" data-required)
				
					//single form item
					.form-item-group
						.form-label E-mail*
						.form-item
							input.form-inp(type="email" name="EMAIL" value="<?= $data['EMAIL'] ?>" data-required)
					
			
			//BLOCK №2
			.fieldset.border-0
				.fieldset-title 2. Параметры
				//single form item
				.form-item-group
					.form-label Тип оборудования:
					.form-radio-row.row-mobile
						label.form-radio-label
							input(type="radio" checked name="type" value="1")
							span.fake-radio
							span.form-radio-name.fs-16 Термокомпрессор
						
						label.form-radio-label
							input(type="radio" name="type" value="2")
							span.fake-radio
							span.form-radio-name.fs-16 Циркуляционный эжектор
			
				//группа внутри одного fieldset
				.fieldset-group.fieldset-sticky-header
					
					//ряд
					.fieldset-sticky-title.fieldset-sticky-row
						//Левая колонка
						.fieldset-group-title Параметр
						//Три правые колонки
						.fieldset-sticky-cols
							.inner-row
								.fieldset-cell.fs-15 Пар низкого давления
								.fieldset-cell.fs-15 Пар среднего давления
								.fieldset-cell.fs-15 Пар высокого давления
					
					//ряд
					.fieldset-sticky-row
						//Левая колонка
						.fieldset-cell-name Давление
						
						//Три правые колонки
						.fieldset-sticky-cols
							.inner-row
								.fieldset-cell.form-item
									input.form-inp(type="number" name="pn1" required)
									span.form-span бар изб
								.fieldset-cell.form-item
									input.form-inp(type="number" name="pm1" required)
									span.form-span бар изб
								.fieldset-cell.form-item
									input.form-inp(type="number" name="pv1" required)
									span.form-span бар изб
					
					.fieldset-sticky-row
						//Левая колонка
						.fieldset-cell-name Температура
						//Три правые колонки
						.fieldset-sticky-cols
							.inner-row
								.fieldset-cell.form-item
									input.form-inp(type="number" name="pn2" required)
									span.form-span °С
								.fieldset-cell.form-item
									input.form-inp(type="number" name="pm2" required)
									span.form-span °С
								.fieldset-cell.form-item
									input.form-inp(type="number" name="pv2" required)
									span.form-span °С
					.fieldset-sticky-row
						//Левая колонка
						.fieldset-cell-name Расход
						//Три правые колонки
						.fieldset-sticky-cols
							.inner-row
								.fieldset-cell.form-item
									input.form-inp(type="number" name="pn3" required)
									span.form-span кг/ч
								.fieldset-cell.form-item
									input.form-inp(type="number" name="pm3" required)
									span.form-span кг/ч
								.fieldset-cell.form-item
									input.form-inp(type="number" name="pv3" required)
									span.form-span кг/ч
		
				.form-two-cols
					//single form item
					.form-item-group
						.form-label Максимальное рабочее давление пара
						.form-item
							input.form-inp(type="text"  name="p1" required)
							span.form-span бар изб
					
					//single form item
					.form-item-group
						.form-label Максимальная рабочая температура пара
						.form-item
							input.form-inp(type="number" name="p2" required)
							span.form-span °C
					
					//single form item
					.form-item-group
						.form-label Материал корпуса
						.form-item
							input.form-inp(type="number"  name="p3" required)
					
					//single form item
					.form-item-group
						.form-label Исполнение эжектора
						.dropdown
							button.dropdown__button(type="button" aria-haspopup="listbox" aria-expanded="false") 
							.dropdown__list
								ul
									li.dropdown__list-item
										label.form-radio-label
											input(type="radio" name="isp" value="1" checked )
											span.form-radio-name Регулируемый -с приводом
									li.dropdown__list-item
										label.form-radio-label
											input(type="radio" name="isp" value="2" )
											span.form-radio-name Нерегулируемый - без привода
							
					
					//single form item
					.form-item-group
						.form-label Тип присоединения
						.dropdown
							button.dropdown__button(type="button" aria-haspopup="listbox" aria-expanded="false")
							.dropdown__list
								ul
									li.dropdown__list-item
										label.form-radio-label
											input(type="radio"  name="typep"  value="1" checked )
											span.form-radio-name Резьбовой
									li.dropdown__list-item
										label.form-radio-label
											input(type="radio" name="typep"  value="2" )
											span.form-radio-name Фланцевый
									li.dropdown__list-item
										label.form-radio-label
											input(type="radio"  name="typep"  value="3" )
											span.form-radio-name Приварной
							
							
					//single form item
					.form-item-group
						.form-label Стандарт исполнения присоединения
						.form-radio-row
							label.form-radio-label
								input(type="radio" checked name="standpri" value="1")
								span.fake-radio
								span.form-radio-name DIN
							
							label.form-radio-label
								input(type="radio" name="standpri" value="2")
								span.fake-radio
								span.form-radio-name ANSI / ASME
				
				//Поле комментария
				.fieldset-group 
					.form-item-group
						.form-label Примечание
						textarea.form-textarea(name="COMMENTS" id="input")
				.form-footer
					p.fs-15.txt-grey * Если вы затрудняетесь в определении каких-либо значений, свяжитесь с нами, мы поможем их определить, основываясь на дополнительной информации о процессе / установке. Поля, отмеченные *, являются обязательными для заполнения.
					.agree-block
						label.agree-block-label
							input(type="checkbox")
							span Принимаю условия политики конфиден&shy;ци&shy;аль&shy;ности и обработки персональных данных
					.form-button-wrapper
						button.form-button(type="submit") Отправить
block variables
	-var title = "Эжектор";
